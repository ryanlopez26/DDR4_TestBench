# ============================================================
# DDR4_TestBench .gitignore
# ============================================================

# ── EDF / Yocto Build Artifacts ─────────────────────────────
# These are generated by bitbake and can be 10-100GB+
EDF/build/tmp*/
EDF/build/cache/
EDF/build/bitbake*.log
EDF/build/bitbake*.lock
EDF/build/bitbake*.sock
EDF/build/.bitbake.lock

# Yocto sstate and download caches live in /tools/edf
# but exclude if accidentally placed in project
EDF/sstate-cache/
EDF/downloads/

# Keep configuration files but ignore generated machine configs
# (these are regenerated by gen-machineconf)
EDF/build/conf/sanity_info
EDF/build/.hw-description/

# ── Vivado Build Artifacts ───────────────────────────────────
# Implementation and synthesis outputs (regenerated by Vivado)
Vivado/*.cache/
Vivado/*.runs/
Vivado/*.sim/
Vivado/*.gen/
Vivado/*.hw/
Vivado/*.ip_user_files/
Vivado/*.hbs

# Vivado log and journal files
Vivado/*.log
Vivado/*.jou
Vivado/ip_upgrade.log
Vivado/.Xil/

# Vivado backup files
Vivado/**/*.bak
Vivado/**/*_bak*

# Large generated files
Vivado/**/*.bit
Vivado/**/*.ltx
Vivado/**/*.mmi
Vivado/**/*.ll

# Keep XSA - needed for EDF build
# Keep XPR - needed to reopen project
# Keep srcs - source files should be tracked

# ── Docker ───────────────────────────────────────────────────
# Keep Dockerfile and run scripts
# Ignore any local overrides
Docker/*.local
Docker/.env

# ── Editor / OS Artifacts ────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Compiled binaries ────────────────────────────────────────
*.o
*.a
*.so
*.elf

# Rust
zcu_app/target/
zcu_app/Cargo.lock

# ── C# / .NET / Visual Studio ────────────────────────────────
# Build outputs (case-insensitive: bin/Bin/BIN, obj/Obj/OBJ, etc.)
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/

# Visual Studio cache / user-specific files
.vs/
*.suo
*.user
*.userprefs
*.userosscache
*.sln.docstates
*.sln.iml

# Roslyn / build server
.builds/
*.[Cc]ache
!?*.[Cc]ache/

# NuGet (keep .config and lock files; ignore restored packages)
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# Test / publish / coverage output
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
[Pp]ublish/
PublishScripts/
*.coverage
*.coveragexml
coverage*.json
coverage*.xml
coverage*.info

# Visual Studio profiler / diagnostics
*.psess
*.vsp
*.vspx
*.sap

# ReSharper / Rider (.idea/ already ignored above)
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Misc dev tooling artifacts
*.pidb
*.svclog
*.scc
*.tmp
*.tlog

# ============================================================
# What IS tracked:
#
# Docker/
#   Dockerfile
#   run-yocto.sh
#   run-sdk.sh
#
# EDF/
#   zcu104-ddr4.yml          (kas config)
#   build/conf/local.conf    (build config)
#   build/conf/bblayers.conf (layer config)
#   sources/meta-zcu104-ddr4/ (custom BSP layer)
#
# Vivado/
#   *.xpr                    (project file)
#   *.srcs/                  (source files)
#   System_wrapper.xsa       (hardware export)
#   sdt_output/              (SDT from sdtgen)
#
# C# app/
#   *.sln, *.csproj          (project / solution files)
#   *.cs, *.xaml, *.resx     (source / UI / resources)
#   App.config, *.json       (app configuration)
# ============================================================