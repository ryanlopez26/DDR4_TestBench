# ============================================================
# DDR4_TestBench .gitignore
# ============================================================

# ── EDF / Yocto Build Artifacts ─────────────────────────────
# These are generated by bitbake and can be 10-100GB+
EDF/build/tmp*/
EDF/build/cache/
EDF/build/bitbake*.log
EDF/build/bitbake*.lock
EDF/build/bitbake*.sock
EDF/build/.bitbake.lock

# Yocto sstate and download caches live in /tools/edf
# but exclude if accidentally placed in project
EDF/sstate-cache/
EDF/downloads/

# Keep configuration files but ignore generated machine configs
# (these are regenerated by gen-machineconf)
EDF/build/conf/sanity_info
EDF/build/.hw-description/

# ── Vivado Build Artifacts ───────────────────────────────────
# Implementation and synthesis outputs (regenerated by Vivado)
Vivado/*.cache/
Vivado/*.runs/
Vivado/*.sim/
Vivado/*.gen/
Vivado/*.hw/
Vivado/*.ip_user_files/
Vivado/*.hbs

# Vivado log and journal files
Vivado/*.log
Vivado/*.jou
Vivado/ip_upgrade.log
Vivado/.Xil/

# Vivado backup files
Vivado/**/*.bak
Vivado/**/*_bak*

# Large generated files
Vivado/**/*.bit
Vivado/**/*.ltx
Vivado/**/*.mmi
Vivado/**/*.ll

# Keep XSA - needed for EDF build
# Keep XPR - needed to reopen project
# Keep srcs - source files should be tracked

# ── Docker ───────────────────────────────────────────────────
# Keep Dockerfile and run scripts
# Ignore any local overrides
Docker/*.local
Docker/.env

# ── Editor / OS Artifacts ────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Compiled binaries ────────────────────────────────────────
*.o
*.a
*.so
*.elf

# Rust
zcu_app/target/
zcu_app/Cargo.lock

# ============================================================
# What IS tracked:
#
# Docker/
#   Dockerfile
#   run-yocto.sh
#   run-sdk.sh
#
# EDF/
#   zcu104-ddr4.yml          (kas config)
#   build/conf/local.conf    (build config)
#   build/conf/bblayers.conf (layer config)
#   sources/meta-zcu104-ddr4/ (custom BSP layer)
#
# Vivado/
#   *.xpr                    (project file)
#   *.srcs/                  (source files)
#   System_wrapper.xsa       (hardware export)
#   sdt_output/              (SDT from sdtgen)
# ============================================================
